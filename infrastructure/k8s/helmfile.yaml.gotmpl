repositories:
  - name: traefik
    url: https://traefik.github.io/charts
  - name: bitnami
    url: https://charts.bitnami.com/bitnami
  - name: prometheus-community
    url: https://prometheus-community.github.io/helm-charts
  - name: grafana
    url: https://grafana.github.io/helm-charts

environments:
  mac-mini:
    values:
      - environments/mac-mini.yaml
  dev:
    values:
      - environments/dev.yaml
  prod:
    values:
      - environments/prod.yaml

---

releases:
  # ===================================================================
  # Cluster Services
  # ===================================================================

  # In-cluster container registry. Used instead of ECR/GHCR because for a
  # single-node K3s setup there is no benefit to a managed registry — the only
  # consumer is on the same node. Eliminates external dependencies and cost.
  # To switch to ECR/GHCR later, just change the REGISTRY env var.
  - name: registry
    namespace: registry
    chart: charts/registry
    createNamespace: true
    values:
      - persistence:
          enabled: {{ .Values | get "persistence" true }}
          size: {{ env "REGISTRY_VOLUME_SIZE" | default "20Gi" }}

  # CoreDNS for resolving service hostnames (*.mac-mini) via Tailscale Split DNS.
  # All tailnet devices resolve app.mac-mini, api.mac-mini, etc. without /etc/hosts.
  - name: dns
    namespace: dns
    chart: charts/dns
    createNamespace: true
    values:
      - domain: {{ env "DNS_DOMAIN" | default (requiredEnv "DEV_HOSTNAME") }}
        tailscaleIP: {{ env "TAILSCALE_IP" | default "127.0.0.1" }}

  - name: traefik
    namespace: traefik
    chart: traefik/traefik
    version: "34.3.0"
    createNamespace: true
    values:
      - ports:
          web:
            port: 8000
            exposedPort: 80
          websecure:
            port: 8443
            exposedPort: 443
        ingressRoute:
          dashboard:
            enabled: {{ env "TRAEFIK_DASHBOARD" | default "false" }}
        logs:
          general:
            level: {{ env "TRAEFIK_LOG_LEVEL" | default "INFO" }}

  # Tailscale gateway — gives minikube its own tailnet IP so all devices
  # can reach services by hostname without /etc/hosts entries.
  # Only deployed when TS_AUTHKEY is set (local dev only, not remote servers).
  {{- if env "TS_AUTHKEY" }}
  - name: tailscale-gateway
    namespace: tailscale
    chart: charts/tailscale-gateway
    createNamespace: true
    needs:
      - traefik/traefik
    values:
      - hostname: {{ env "TS_GATEWAY_HOSTNAME" | default "macbook-dev-team" }}
        authKey: {{ requiredEnv "TS_AUTHKEY" }}
        domain: {{ requiredEnv "DEV_HOSTNAME" }}
        gatewayIP: {{ env "TS_GATEWAY_IP" | default "" }}
        traefik:
          clusterIP: {{ env "TRAEFIK_CLUSTER_IP" | default "" }}
  {{- end }}

  # ===================================================================
  # Application Services (namespace: app)
  # ===================================================================

  - name: database
    namespace: {{ env "NAMESPACE" | default "app" }}
    chart: ../../projects/application/database/chart
    createNamespace: true
    values:
      - image:
          repository: {{ env "DATABASE_IMAGE" | default "pgvector/pgvector" }}
          tag: {{ env "DATABASE_IMAGE_TAG" | default "pg16" }}
        env:
          POSTGRES_DB: {{ env "DATABASE_NAME" | default "postgres" }}
          POSTGRES_USER: {{ env "DATABASE_USERNAME" | default "postgres" }}
          POSTGRES_PASSWORD: {{ requiredEnv "DATABASE_PASSWORD" }}
        persistence:
          enabled: {{ .Values | get "persistence" true }}
          size: {{ env "DATABASE_VOLUME_SIZE" | default "10Gi" }}
        resources:
          requests:
            memory: {{ env "DATABASE_MEMORY_REQUEST" | default "256Mi" }}
            cpu: {{ env "DATABASE_CPU_REQUEST" | default "100m" }}
          limits:
            memory: {{ env "DATABASE_MEMORY_LIMIT" | default "512Mi" }}
            cpu: {{ env "DATABASE_CPU_LIMIT" | default "500m" }}
        pgweb:
          enabled: true
          ingress:
            enabled: true
            host: {{ env "PGWEB_HOST" | default (print "db." (requiredEnv "DEV_HOSTNAME")) }}
            tls: {{ .Values | get "ingressTLS" false }}

  - name: backend
    namespace: {{ env "NAMESPACE" | default "app" }}
    chart: ../../projects/application/backend/chart
    needs:
      - {{ env "NAMESPACE" | default "app" }}/database
    values:
      - image:
          repository: {{ env "BACKEND_IMAGE" | default (print (env "REGISTRY" | default "localhost:30500") "/backend") }}
          tag: {{ env "IMAGE_TAG" | default "latest" }}
        replicas: {{ env "BACKEND_REPLICAS" | default "1" }}
        ingress:
          enabled: true
          host: {{ env "BACKEND_HOST" | default (print "api." (requiredEnv "DEV_HOSTNAME")) }}
          tls: {{ .Values | get "ingressTLS" false }}
        env:
          NODE_ENV: {{ env "NODE_ENV" | default "production" }}
          PORT: {{ env "K8S_SERVICE_PORT" | default "8080" }}
          SERVICE_NAME: {{ env "BACKEND_SERVICE_NAME" | default "backend" }}
          DATABASE_HOST: {{ env "DATABASE_HOST" | default "database" }}
          DATABASE_PORT: {{ env "DATABASE_K8S_PORT" | default "5432" }}
          DATABASE_NAME: {{ env "DATABASE_NAME" | default "postgres" }}
          DATABASE_USERNAME: {{ env "DATABASE_USERNAME" | default "postgres" }}
          DATABASE_SSL: {{ env "DATABASE_SSL" | default "false" }}
          KEYCLOAK_REALM: {{ env "KEYCLOAK_REALM" | default "application" }}
          KEYCLOAK_CLIENT_ID: {{ env "KEYCLOAK_CLIENT_ID" | default "backend-service" }}
          CORS_ORIGINS: "{{ env "CORS_ORIGINS" | default "*" }}"
        secretEnv:
          DATABASE_PASSWORD: {{ requiredEnv "DATABASE_PASSWORD" }}
          KEYCLOAK_CLIENT_SECRET: {{ env "KEYCLOAK_CLIENT_SECRET" | default "backend-service-secret" }}
          OPENAI_API_KEY: {{ env "OPENAI_API_KEY" | default "" }}
          ANTHROPIC_API_KEY: {{ env "ANTHROPIC_API_KEY" | default "" }}
          GOOGLE_GENERATIVE_AI_API_KEY: {{ env "GOOGLE_GENERATIVE_AI_API_KEY" | default "" }}
        resources:
          requests:
            memory: {{ env "BACKEND_MEMORY_REQUEST" | default "256Mi" }}
            cpu: {{ env "BACKEND_CPU_REQUEST" | default "100m" }}
          limits:
            memory: {{ env "BACKEND_MEMORY_LIMIT" | default "512Mi" }}
            cpu: {{ env "BACKEND_CPU_LIMIT" | default "500m" }}

  - name: keycloak
    namespace: {{ env "NAMESPACE" | default "app" }}
    chart: ../../projects/application/keycloak/chart
    needs:
      - {{ env "NAMESPACE" | default "app" }}/database
    values:
      - image:
          repository: {{ env "KEYCLOAK_IMAGE" | default (print (env "REGISTRY" | default "localhost:30500") "/keycloak") }}
          tag: {{ env "IMAGE_TAG" | default "latest" }}
        ingress:
          enabled: true
          host: {{ env "KEYCLOAK_HOST" | default (print "auth." (requiredEnv "DEV_HOSTNAME")) }}
          tls: {{ .Values | get "ingressTLS" false }}
        env:
          KC_DB: {{ env "KC_DB" | default "postgres" }}
          KC_DB_URL: {{ env "KC_DB_URL" | default (print "jdbc:postgresql://" (env "DATABASE_HOST" | default "database") ":" (env "DATABASE_K8S_PORT" | default "5432") "/" (env "DATABASE_NAME" | default "postgres") "?sslmode=disable") }}
          KC_DB_SCHEMA: {{ env "KC_DB_SCHEMA" | default "keycloak" }}
          KC_DB_USERNAME: {{ env "DATABASE_USERNAME" | default "postgres" }}
          KC_REALM: {{ env "KEYCLOAK_REALM" | default "application" }}
          KC_CLIENT_ID: {{ env "KEYCLOAK_CLIENT_ID" | default "backend-service" }}
          KC_LOG_LEVEL: {{ env "KC_LOG_LEVEL" | default "INFO" }}
          KC_TRANSACTION_XA_ENABLED: {{ env "KC_TRANSACTION_XA_ENABLED" | default "false" }}
          KC_IMPORT_OVERWRITE: {{ env "KC_IMPORT_OVERWRITE" | default "true" }}
          KEYCLOAK_ADMIN: {{ env "KEYCLOAK_ADMIN" | default "admin" }}
        secretEnv:
          KC_DB_PASSWORD: {{ requiredEnv "DATABASE_PASSWORD" }}
          KEYCLOAK_ADMIN_PASSWORD: {{ requiredEnv "KEYCLOAK_ADMIN_PASSWORD" }}
          KEYCLOAK_CLIENT_SECRET: {{ env "KEYCLOAK_CLIENT_SECRET" | default "backend-service-secret" }}
        resources:
          requests:
            memory: {{ env "KEYCLOAK_MEMORY_REQUEST" | default "512Mi" }}
            cpu: {{ env "KEYCLOAK_CPU_REQUEST" | default "200m" }}
          limits:
            memory: {{ env "KEYCLOAK_MEMORY_LIMIT" | default "1Gi" }}
            cpu: {{ env "KEYCLOAK_CPU_LIMIT" | default "1000m" }}

  - name: frontend
    namespace: {{ env "NAMESPACE" | default "app" }}
    chart: ../../projects/application/frontend/chart
    needs:
      - {{ env "NAMESPACE" | default "app" }}/backend
      - {{ env "NAMESPACE" | default "app" }}/keycloak
    values:
      - image:
          repository: {{ env "FRONTEND_IMAGE" | default (print (env "REGISTRY" | default "localhost:30500") "/frontend") }}
          tag: {{ env "IMAGE_TAG" | default "latest" }}
        replicas: {{ env "FRONTEND_REPLICAS" | default "1" }}
        ingress:
          enabled: true
          host: {{ env "FRONTEND_HOST" | default (print "app." (requiredEnv "DEV_HOSTNAME")) }}
          tls: {{ .Values | get "ingressTLS" false }}
        apiProxy:
          enabled: true
          backendService: {{ env "FRONTEND_API_PROXY_SERVICE" | default "backend" }}
          backendPort: {{ env "FRONTEND_API_PROXY_PORT" | default "8080" }}
        resources:
          requests:
            memory: {{ env "FRONTEND_MEMORY_REQUEST" | default "128Mi" }}
            cpu: {{ env "FRONTEND_CPU_REQUEST" | default "50m" }}
          limits:
            memory: {{ env "FRONTEND_MEMORY_LIMIT" | default "256Mi" }}
            cpu: {{ env "FRONTEND_CPU_LIMIT" | default "200m" }}

  # ===================================================================
  # THE Dev Team (namespace: the-dev-team)
  # ===================================================================

  - name: the-dev-team-backend
    namespace: {{ env "THE_DEV_TEAM_NAMESPACE" | default "the-dev-team" }}
    chart: ../../projects/the-dev-team/backend/chart
    createNamespace: true
    values:
      - image:
          repository: {{ env "THE_DEV_TEAM_BACKEND_IMAGE" | default (print (env "REGISTRY" | default "localhost:30500") "/the-dev-team-backend") }}
          tag: {{ env "IMAGE_TAG" | default "latest" }}
        ingress:
          enabled: true
          host: {{ env "THE_DEV_TEAM_BACKEND_HOST" | default (print "agent-api." (requiredEnv "DEV_HOSTNAME")) }}
          tls: {{ .Values | get "ingressTLS" false }}
        env:
          NODE_ENV: {{ env "NODE_ENV" | default "production" }}
          PORT: "8080"
          REPO_ROOT: /workspace
          CORS_ORIGINS: "{{ env "CORS_ORIGINS" | default "*" }}"
          DEV_HOSTNAME: {{ requiredEnv "DEV_HOSTNAME" }}
        secretEnv:
          CLAUDE_CODE_OAUTH_TOKEN: {{ env "CLAUDE_CODE_OAUTH_TOKEN" | default "" }}
          ANTHROPIC_API_KEY: {{ env "ANTHROPIC_API_KEY" | default "" }}
          GITHUB_TOKEN: {{ env "GITHUB_TOKEN" | default "" }}
          GITHUB_APP_ID: "{{ env "GITHUB_APP_ID" | default "" }}"
          GITHUB_APP_INSTALLATION_ID: "{{ env "GITHUB_APP_INSTALLATION_ID" | default "" }}"
        githubApp:
          privateKeySecret: {{ env "GITHUB_APP_PRIVATE_KEY_SECRET" | default "" }}
        workspace:
          enabled: true
          size: {{ env "THE_DEV_TEAM_WORKSPACE_SIZE" | default "50Gi" }}
          repoOwner: {{ env "REPO_OWNER" | default "ArchiCain" }}
          repoName: {{ env "REPO_NAME" | default "automated-coding-agent" }}
        resources:
          requests:
            memory: "512Mi"
            cpu: "200m"
          limits:
            memory: "2Gi"
            cpu: "2000m"

  - name: the-dev-team-frontend
    namespace: {{ env "THE_DEV_TEAM_NAMESPACE" | default "the-dev-team" }}
    chart: ../../projects/the-dev-team/frontend/chart
    createNamespace: true
    values:
      - image:
          repository: {{ env "THE_DEV_TEAM_FRONTEND_IMAGE" | default (print (env "REGISTRY" | default "localhost:30500") "/the-dev-team-frontend") }}
          tag: {{ env "IMAGE_TAG" | default "latest" }}
        ingress:
          enabled: true
          host: {{ env "THE_DEV_TEAM_FRONTEND_HOST" | default (print "devteam." (requiredEnv "DEV_HOSTNAME")) }}
        resources:
          requests:
            memory: "128Mi"
            cpu: "50m"
          limits:
            memory: "256Mi"
            cpu: "200m"

  # ===================================================================
  # Observability Stack (namespace: monitoring)
  # ===================================================================

  - name: kube-prometheus-stack
    namespace: monitoring
    chart: prometheus-community/kube-prometheus-stack
    version: "72.6.2"
    createNamespace: true
    values:
      - grafana:
          enabled: true
          adminUser: admin
          adminPassword: {{ env "GRAFANA_ADMIN_PASSWORD" | default "admin" }}
          service:
            type: ClusterIP
            port: 3000
          "grafana.ini":
            server:
              root_url: "http://localhost:3000"
              serve_from_sub_path: false
            auth.anonymous:
              enabled: true
              org_role: Viewer
            security:
              allow_embedding: true
          additionalDataSources:
            - name: Loki
              type: loki
              url: http://loki.monitoring:3100
              access: proxy
              isDefault: false
          resources:
            requests:
              memory: "256Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "500m"
        prometheus:
          prometheusSpec:
            podMonitorSelectorNilUsesHelmValues: false
            serviceMonitorSelectorNilUsesHelmValues: false
            retention: 7d
            resources:
              requests:
                memory: "512Mi"
                cpu: "200m"
              limits:
                memory: "1Gi"
                cpu: "1000m"
            storageSpec:
              volumeClaimTemplate:
                spec:
                  accessModes: ["ReadWriteOnce"]
                  resources:
                    requests:
                      storage: 10Gi
        alertmanager:
          enabled: false
        nodeExporter:
          enabled: true
        kubeStateMetrics:
          enabled: true

  - name: loki
    namespace: monitoring
    chart: grafana/loki
    version: "6.29.0"
    createNamespace: true
    values:
      - deploymentMode: SingleBinary
        loki:
          auth_enabled: false
          commonConfig:
            replication_factor: 1
          schemaConfig:
            configs:
              - from: "2024-01-01"
                store: tsdb
                object_store: filesystem
                schema: v13
                index:
                  prefix: index_
                  period: 24h
          storage:
            type: filesystem
          limits_config:
            retention_period: 168h
        singleBinary:
          replicas: 1
          resources:
            requests:
              memory: "256Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "500m"
          persistence:
            enabled: true
            size: 10Gi
        gateway:
          enabled: false
        backend:
          replicas: 0
        read:
          replicas: 0
        write:
          replicas: 0
        chunksCache:
          enabled: false
        resultsCache:
          enabled: false

  - name: promtail
    namespace: monitoring
    chart: grafana/promtail
    version: "6.16.6"
    createNamespace: true
    values:
      - config:
          clients:
            - url: http://loki.monitoring:3100/loki/api/v1/push
        resources:
          requests:
            memory: "64Mi"
            cpu: "25m"
          limits:
            memory: "128Mi"
            cpu: "100m"

