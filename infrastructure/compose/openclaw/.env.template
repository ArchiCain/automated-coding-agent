# Copy to compose/openclaw/.env before running task openclaw:up
# (this file is named .env.template per repo convention; root .gitignore
# negates it from the .env.* ignore rule so the template stays tracked
# while `.env` does not.)
#
# Variables consumed by compose/openclaw/compose.yml.

# --- Anthropic / OpenAI API keys ---
# Required — the gateway's entrypoint refuses to start without them.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Gateway auth ---
# The Control UI prompts for this token on first connect. Generate any
# random high-entropy string (e.g. `openssl rand -hex 32`); agents never
# see it — it only gates the browser-to-gateway pairing flow.
OPENCLAW_AUTH_TOKEN=

# --- GitHub App for the git-sync sidecar ---
# The sidecar mints installation access tokens from this app and uses
# them to clone + pull $GIT_REPO_URL. The private key is read from a
# host path that compose bind-mounts into git-sync at
# /etc/github-app/private-key.pem (read-only).
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_HOST_PATH=/Users/YOU/.openclaw-secrets/github-app-key.pem

# Repo the git-sync sidecar keeps synced under /workspace/repo.
GIT_REPO_URL=https://github.com/rtslabs/scain-coding-agent.git

# --- Optional overrides ---
# Branch the sidecar tracks (also used by the gateway's git identity).
OPENCLAW_GIT_BRANCH=dev
# GitHub App slug used to build the bot identity the gateway commits as.
OPENCLAW_GIT_APP_SLUG=scain-openclaw

# --- Host-specific ---
# Supplemental gid added to the gateway container so uid 1000 (`node`) can
# open /var/run/docker.sock. Run `stat -c %g /var/run/docker.sock` (Linux)
# or `docker compose -f compose/openclaw/compose.yml exec gateway stat -c %g
# /var/run/docker.sock` after first boot to confirm.
#   Docker Desktop (mac) / Colima (mac): 0   (socket is root:root)
#   Ubuntu (EC2):                        gid of the `docker` group
#                                        (e.g. `getent group docker | cut -d: -f3`)
DOCKER_SOCKET_GID=0
