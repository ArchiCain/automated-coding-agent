# Variables consumed by compose/openclaw/compose.yml.
#
# In production, the GH Actions deploy workflow renders this file from
# repo secrets/vars and rsyncs it onto host-machine — you don't write
# it by hand. This template documents the variable set.

# --- Anthropic / OpenAI API keys ---
# Required — the gateway's entrypoint refuses to start without them.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Gateway auth ---
# The Control UI prompts for this token on first connect. Generate any
# random high-entropy string (e.g. `openssl rand -hex 32`); agents never
# see it — it only gates the browser-to-gateway pairing flow.
OPENCLAW_AUTH_TOKEN=

# --- GitHub App (for the git-sync sidecar only — GHCR pulls are public) ---
# Required permissions on this repo:
#   Contents: Read
#   Metadata: Read
# The compose stack bind-mounts the PEM at the host path below into
# git-sync at /etc/github-app/private-key.pem. The deploy workflow
# writes the PEM to /srv/aca/secrets/github-app.pem — the default below.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_HOST_PATH=/srv/aca/secrets/github-app.pem

# Repo the git-sync sidecar keeps synced at /workspace/repo.
GIT_REPO_URL=https://github.com/ArchiCain/automated-coding-agent.git

# --- Optional ---
# Supplemental gid added to the gateway container so uid 1000 (`node`)
# can open /var/run/docker.sock. compose.yml defaults this to 999
# (the typical Ubuntu docker group GID). Override only if your host's
# `docker` group has a different gid:
#   getent group docker | cut -d: -f3
DOCKER_SOCKET_GID=
