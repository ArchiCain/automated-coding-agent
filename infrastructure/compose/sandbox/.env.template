# This file is normally bypassed — `scripts/sandbox-deploy.sh` sets these
# variables inline when it invokes `docker compose up`. This template exists
# for manual debugging:
#   docker compose -f compose/sandbox/compose.yml --env-file compose/sandbox/.env up
#
# Variables consumed by compose/sandbox/compose.yml. The deploy script
# allocates the port triple from 20000-29990 (multiples of 10) via
# deterministic-hash-with-collision-bump. See compose/sandbox/compose.yml for
# field-by-field docs.

# Sandbox identifier — lowercase alphanumeric + hyphen, 1-41 chars.
# Also used as the compose project suffix (`-p env-${SANDBOX_ID}`).
SANDBOX_ID=

# Host ports published for each service. The container side is always :8080.
SANDBOX_BASE_PORT_FRONTEND=
SANDBOX_BASE_PORT_BACKEND=
SANDBOX_BASE_PORT_KEYCLOAK=

# Image tag for the three built service images. Defaults to SANDBOX_ID in
# the compose file if unset. The deploy script always builds images before
# bringing compose up, so the tag exists locally by the time compose runs.
IMAGE_TAG=
