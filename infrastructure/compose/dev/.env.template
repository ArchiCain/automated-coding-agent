# Copy to compose/dev/.env before running docker compose up
# (this file is named .env.template per repo convention; root .gitignore
# line 46 negates it from the .env.* ignore rule so the template stays
# tracked while `.env` does not.)
#
# Variables consumed by compose/dev/compose.yml. Defaults below match the
# k8s chart values so backend migrations, realm imports, and client
# secrets line up without surprises.

# Postgres superuser created on first boot of the pgvector container.
# Used by backend (DATABASE_USERNAME / DATABASE_PASSWORD) and keycloak
# (KC_DB_USERNAME / KC_DB_PASSWORD) to connect to the shared postgres.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database name created on first boot. Backend connects here directly;
# keycloak creates its own `keycloak` schema inside this database.
POSTGRES_DB=app

# Shared secret for the Keycloak `backend-service` confidential client.
# Backend uses it to exchange auth codes / service-account tokens against
# Keycloak. Must match the client secret in realm-export.json.
KEYCLOAK_CLIENT_SECRET=backend-service-secret
