import {
  Component,
  Input,
  Output,
  EventEmitter,
  OnInit,
  OnDestroy,
  inject,
  signal,
  ViewChild,
  ElementRef,
} from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { Router, RouterModule } from '@angular/router';
import { MatIconModule } from '@angular/material/icon';
import { MatButtonModule } from '@angular/material/button';
import { MatProgressSpinnerModule } from '@angular/material/progress-spinner';
import { MatTabsModule } from '@angular/material/tabs';
import { Subscription, interval } from 'rxjs';
import {
  AgentsService,
  SessionMetadata,
  AgentDefinition,
} from '../../../features/agents/services/agents.service';
import { AgentsWebSocketService } from '../../../features/agents/services/agents-websocket.service';
import { FileSlideOverComponent } from '../file-slide-over/file-slide-over';

type TabType = 'active' | 'inactive' | 'definitions';
type ViewMode = 'list' | 'session' | 'definition';

@Component({
  selector: 'app-agents-drawer',
  standalone: true,
  imports: [
    CommonModule,
    FormsModule,
    RouterModule,
    MatIconModule,
    MatButtonModule,
    MatProgressSpinnerModule,
    MatTabsModule,
    FileSlideOverComponent,
  ],
  templateUrl: './agents-drawer.html',
  styleUrl: './agents-drawer.scss',
})
export class AgentsDrawerComponent implements OnInit, OnDestroy {
  @ViewChild('outputContainer') outputContainer!: ElementRef<HTMLDivElement>;
  @ViewChild('chatInputEl') chatInputEl!: ElementRef<HTMLTextAreaElement>;
  @ViewChild('defChatInputEl') defChatInputEl!: ElementRef<HTMLTextAreaElement>;

  @Input() set isOpen(value: boolean) {
    this._isOpen = value;
    if (value) {
      // Reload sessions each time drawer opens
      this.loadSessions();
      // Load definitions if not already loaded
      if (this.definitions().length === 0) {
        this.loadDefinitions();
      }
    } else {
      // Reset to list view when drawer closes
      this.viewMode.set('list');
      this.selectedSession.set(null);
      this.selectedDefinition.set(null);
      this.viewingFile.set(null);
    }
  }
  get isOpen(): boolean {
    return this._isOpen;
  }
  private _isOpen = false;

  @Output() closed = new EventEmitter<void>();

  private router = inject(Router);
  private agentsService = inject(AgentsService);
  private wsService = inject(AgentsWebSocketService);

  // List view state
  activeSessions = signal<SessionMetadata[]>([]);
  inactiveSessions = signal<SessionMetadata[]>([]);
  loading = signal(true);
  endingSession = signal<string | null>(null);
  activeTab = signal<TabType>('active');

  // Track which sessions are currently processing (vs waiting for input)
  processingSessions = signal<Set<string>>(new Set());

  // Agent definitions state
  definitions = signal<AgentDefinition[]>([]);
  definitionsLoading = signal(false);
  selectedDefinition = signal<AgentDefinition | null>(null);
  definitionFileContent = signal<string | null>(null);
  definitionFileLoading = signal(false);
  viewingFile = signal<{ type: 'prompt' | 'context'; path: string } | null>(null);

  // Definition chat state (for testing agents in definition view)
  definitionSession = signal<SessionMetadata | null>(null);
  definitionChatInput = signal('');
  definitionProcessing = signal(false);
  infoCollapsed = signal(false);

  // File attachment state
  pendingAttachments = signal<Array<{
    id: string;
    type: 'file' | 'image';
    name: string;
    file: File;
    preview?: string;
  }>>([]);
  private attachmentIdCounter = 0;

  // Session detail view state
  viewMode = signal<ViewMode>('list');
  selectedSession = signal<SessionMetadata | null>(null);
  sessionOutput = signal<string[]>([]);
  sessionLoading = signal(false);
  sessionError = signal<string | null>(null);
  chatInput = signal('');
  processingTurn = signal(false);
  autoScroll = signal(true);

  private subscriptions: Subscription[] = [];
  private durationInterval: Subscription | null = null;
  durations = signal<Record<string, string>>({});

  ngOnInit(): void {
    this.setupWebSocket();
    this.startDurationUpdates();
  }

  ngOnDestroy(): void {
    this.subscriptions.forEach((sub) => sub.unsubscribe());
    this.durationInterval?.unsubscribe();
  }

  private loadSessions(): void {
    this.loading.set(true);

    // Load all sessions and categorize them
    this.agentsService.listSessions().subscribe({
      next: (response) => {
        // Active = status is 'active' (currently running in memory)
        const active = response.sessions.filter((s) => s.status === 'active');
        // Inactive = paused, completed, failed (can be resumed or viewed)
        const inactive = response.sessions.filter((s) => s.status !== 'active');

        this.activeSessions.set(active);
        this.inactiveSessions.set(inactive);
        this.updateDurations();
        this.loading.set(false);
      },
      error: (err) => {
        console.error('Failed to load sessions:', err);
        this.loading.set(false);
      },
    });
  }

  private setupWebSocket(): void {
    this.wsService.connect();
    this.wsService.subscribeToAll();

    this.subscriptions.push(
      this.wsService.onSessionStarted.subscribe((event) => {
        this.activeSessions.update((sessions) => [event.session, ...sessions]);
        // New sessions start as processing
        this.processingSessions.update((set) => new Set(set).add(event.session.sessionId));
        this.updateDurations();
      }),
      this.wsService.onSessionResumed.subscribe((event) => {
        // Move from inactive back to active
        this.inactiveSessions.update((sessions) =>
          sessions.filter((s) => s.sessionId !== event.session.sessionId)
        );
        this.activeSessions.update((sessions) => {
          // Replace if exists, otherwise add
          const existing = sessions.find(
            (s) => s.sessionId === event.session.sessionId
          );
          if (existing) {
            return sessions.map((s) =>
              s.sessionId === event.session.sessionId ? event.session : s
            );
          }
          return [event.session, ...sessions];
        });
        // Resumed sessions are processing
        this.processingSessions.update((set) => new Set(set).add(event.session.sessionId));
        this.updateDurations();
      }),
      this.wsService.onSessionOutput.subscribe((event) => {
        // If we receive output, the session is processing
        this.processingSessions.update((set) => new Set(set).add(event.sessionId));

        // Update session detail view if this is the selected session
        const selected = this.selectedSession();
        if (selected && event.sessionId === selected.sessionId) {
          this.sessionOutput.update((lines) => [...lines, event.line]);
          if (this.autoScroll()) {
            this.scrollToBottom();
          }
        }

        // Update definition chat view if this is the definition session
        const defSession = this.definitionSession();
        if (defSession && event.sessionId === defSession.sessionId) {
          this.sessionOutput.update((lines) => [...lines, event.line]);
          if (this.autoScroll()) {
            this.scrollToBottom();
          }
        }
      }),
      this.wsService.onSessionTurnComplete.subscribe((event) => {
        // Turn complete means waiting for user input, not processing
        this.processingSessions.update((set) => {
          const newSet = new Set(set);
          newSet.delete(event.sessionId);
          return newSet;
        });

        // Update session detail view
        const selected = this.selectedSession();
        if (selected && event.sessionId === selected.sessionId) {
          this.processingTurn.set(false);
          this.focusChatInput();
        }

        // Update definition chat view
        const defSession = this.definitionSession();
        if (defSession && event.sessionId === defSession.sessionId) {
          this.definitionProcessing.set(false);
          this.focusDefinitionChatInput();
        }
      }),
      this.wsService.onSessionPaused.subscribe((event) => {
        // Update status in active sessions
        this.activeSessions.update((sessions) =>
          sessions.map((s) =>
            s.sessionId === event.sessionId ? { ...s, status: 'paused' as const } : s
          )
        );
        // Paused sessions are not processing
        this.processingSessions.update((set) => {
          const newSet = new Set(set);
          newSet.delete(event.sessionId);
          return newSet;
        });

        // Update session detail view
        const selected = this.selectedSession();
        if (selected && event.sessionId === selected.sessionId) {
          this.processingTurn.set(false);
          this.selectedSession.set({ ...selected, status: 'paused' });
        }
      }),
      this.wsService.onSessionCompleted.subscribe((event) => {
        // Remove from active
        this.activeSessions.update((sessions) =>
          sessions.filter((s) => s.sessionId !== event.session.sessionId)
        );
        // Add to inactive (at the top)
        this.inactiveSessions.update((sessions) => [
          event.session,
          ...sessions,
        ]);
        // Remove from processing
        this.processingSessions.update((set) => {
          const newSet = new Set(set);
          newSet.delete(event.session.sessionId);
          return newSet;
        });

        // Update session detail view
        const selected = this.selectedSession();
        if (selected && event.session.sessionId === selected.sessionId) {
          this.processingTurn.set(false);
          this.selectedSession.set(event.session);
        }
      }),
      this.wsService.onSessionError.subscribe((event) => {
        // Update status in active sessions
        this.activeSessions.update((sessions) =>
          sessions.map((s) =>
            s.sessionId === event.sessionId
              ? { ...s, status: 'failed' as const, error: event.error }
              : s
          )
        );
        // Errored sessions are not processing
        this.processingSessions.update((set) => {
          const newSet = new Set(set);
          newSet.delete(event.sessionId);
          return newSet;
        });

        // Update session detail view
        const selected = this.selectedSession();
        if (selected && event.sessionId === selected.sessionId) {
          this.sessionError.set(event.error);
          this.processingTurn.set(false);
        }
      })
    );
  }

  private startDurationUpdates(): void {
    this.durationInterval = interval(1000).subscribe(() => {
      this.updateDurations();
    });
  }

  private updateDurations(): void {
    const newDurations: Record<string, string> = {};
    for (const session of this.activeSessions()) {
      newDurations[session.sessionId] = this.formatDuration(session.startedAt);
    }
    this.durations.set(newDurations);
  }

  close(): void {
    this.closed.emit();
  }

  onBackdropClick(): void {
    this.close();
  }

  viewSession(session: SessionMetadata): void {
    this.selectedSession.set(session);
    this.sessionOutput.set([]);
    this.sessionError.set(null);
    this.sessionLoading.set(true);
    this.viewMode.set('session');

    // Load session transcript
    this.agentsService.getSessionFull(session.sessionId).subscribe({
      next: (data) => {
        this.selectedSession.set(data.session);
        this.sessionOutput.set(data.transcript);
        this.sessionLoading.set(false);

        // Subscribe to session events
        this.wsService.subscribeToSession(session.sessionId);

        // Auto-resume paused sessions
        if (data.session.status === 'paused') {
          this.resumeSelectedSession();
        } else if (data.session.status === 'active') {
          this.processingTurn.set(false);
          this.focusChatInput();
        }

        this.scrollToBottom();
      },
      error: (err) => {
        this.sessionError.set(err.error?.message || 'Failed to load session');
        this.sessionLoading.set(false);
      },
    });
  }

  backToList(): void {
    this.viewMode.set('list');
    this.selectedSession.set(null);
    this.sessionOutput.set([]);
    this.chatInput.set('');
  }

  private resumeSelectedSession(): void {
    const session = this.selectedSession();
    if (!session) return;

    this.sessionError.set(null);
    this.processingTurn.set(false);

    this.agentsService.resumeSession(session.sessionId).subscribe({
      next: (response) => {
        this.selectedSession.set(response.session);
        this.focusChatInput();
      },
      error: (err) => {
        this.sessionError.set(err.message || 'Failed to resume session');
      },
    });
  }

  sendMessage(): void {
    const message = this.chatInput().trim();
    const session = this.selectedSession();
    if (!message || !session || this.processingTurn()) return;

    this.chatInput.set('');
    this.sessionError.set(null);
    this.processingTurn.set(true);

    // Update session status to active
    if (session.status !== 'active') {
      this.selectedSession.set({ ...session, status: 'active' });
    }

    this.agentsService.sendMessage(session.sessionId, message).subscribe({
      error: (err) => {
        this.sessionError.set(err.message || 'Failed to send message');
        this.processingTurn.set(false);
      },
    });
  }

  stopSelectedSession(): void {
    const session = this.selectedSession();
    if (!session) return;

    this.agentsService.pauseSession(session.sessionId).subscribe({
      next: () => {
        this.processingTurn.set(false);
        this.selectedSession.set({ ...session, status: 'paused' });
      },
      error: (err) => {
        this.sessionError.set(err.message || 'Failed to stop session');
      },
    });
  }

  onInputKeydown(event: KeyboardEvent): void {
    // Enter sends, Shift+Enter for newline
    if (event.key === 'Enter' && !event.shiftKey) {
      event.preventDefault();
      this.sendMessage();
    }
  }

  private scrollToBottom(): void {
    setTimeout(() => {
      if (this.outputContainer) {
        const el = this.outputContainer.nativeElement;
        el.scrollTop = el.scrollHeight;
      }
    }, 0);
  }

  private focusChatInput(): void {
    setTimeout(() => {
      if (this.chatInputEl) {
        this.chatInputEl.nativeElement.focus();
      }
    }, 0);
  }

  toggleAutoScroll(): void {
    this.autoScroll.update((v) => !v);
    if (this.autoScroll()) {
      this.scrollToBottom();
    }
  }

  endSession(session: SessionMetadata, event: Event): void {
    event.stopPropagation();
    this.endingSession.set(session.sessionId);

    this.agentsService.endSession(session.sessionId).subscribe({
      next: () => {
        this.endingSession.set(null);
        this.activeSessions.update((sessions) =>
          sessions.filter((s) => s.sessionId !== session.sessionId)
        );
      },
      error: (err) => {
        console.error('Failed to end session:', err);
        this.endingSession.set(null);
      },
    });
  }

  formatDuration(startedAt: string): string {
    const start = new Date(startedAt).getTime();
    const now = Date.now();
    const seconds = Math.floor((now - start) / 1000);

    if (seconds < 60) return `${seconds}s`;
    const minutes = Math.floor(seconds / 60);
    const remainingSeconds = seconds % 60;
    return `${minutes}m ${remainingSeconds}s`;
  }

  formatTimeAgo(timestamp: string): string {
    const date = new Date(timestamp).getTime();
    const now = Date.now();
    const seconds = Math.floor((now - date) / 1000);

    if (seconds < 60) return 'just now';
    const minutes = Math.floor(seconds / 60);
    if (minutes < 60) return `${minutes}m ago`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    return `${days}d ago`;
  }

  getStatusIcon(status: string): string {
    switch (status) {
      case 'completed':
        return 'check_circle';
      case 'failed':
        return 'error';
      case 'paused':
        return 'pause_circle';
      default:
        return 'help';
    }
  }

  getStatusClass(status: string): string {
    return `status-${status}`;
  }

  truncateCwd(cwd: string, maxLength = 40): string {
    if (cwd.length <= maxLength) return cwd;
    return '...' + cwd.slice(-maxLength + 3);
  }

  isProcessing(sessionId: string): boolean {
    return this.processingSessions().has(sessionId);
  }

  setActiveTab(tab: TabType): void {
    this.activeTab.set(tab);
  }

  startNewSession(): void {
    this.router.navigate(['/playground']);
    this.close();
  }

  resumeSession(session: SessionMetadata, event: Event): void {
    event.stopPropagation();
    // Navigate to playground which will auto-resume the session
    this.router.navigate(['/playground'], {
      queryParams: { session: session.sessionId },
    });
    this.close();
  }

  // ==================== Agent Definitions Methods ====================

  private loadDefinitions(): void {
    this.definitionsLoading.set(true);
    this.agentsService.listDefinitions().subscribe({
      next: (response) => {
        this.definitions.set(response.definitions);
        this.definitionsLoading.set(false);
      },
      error: (err) => {
        console.error('Failed to load agent definitions:', err);
        this.definitionsLoading.set(false);
      },
    });
  }

  viewDefinition(definition: AgentDefinition): void {
    this.selectedDefinition.set(definition);
    this.definitionFileContent.set(null);
    this.viewingFile.set(null);
    this.viewMode.set('definition');

    // Load prompt content if not already loaded
    if (definition.promptFile && !definition.promptContent) {
      this.loadDefinitionPrompt(definition);
    }
  }

  private loadDefinitionPrompt(definition: AgentDefinition): void {
    if (!definition.promptFile) return;

    this.definitionFileLoading.set(true);
    this.agentsService.readFile(definition.promptFile).subscribe({
      next: (response) => {
        // Update the definition with the prompt content
        const updated = { ...definition, promptContent: response.content };
        this.selectedDefinition.set(updated);
        this.definitionFileContent.set(response.content);
        this.definitionFileLoading.set(false);
      },
      error: (err) => {
        console.error('Failed to load prompt file:', err);
        this.definitionFileLoading.set(false);
      },
    });
  }

  viewDefinitionFile(type: 'prompt' | 'context', path: string): void {
    this.viewingFile.set({ type, path });
    this.definitionFileLoading.set(true);
    this.definitionFileContent.set(null);

    this.agentsService.readFile(path).subscribe({
      next: (response) => {
        this.definitionFileContent.set(response.content);
        this.definitionFileLoading.set(false);
      },
      error: (err) => {
        console.error('Failed to load file:', err);
        this.definitionFileContent.set('Error loading file');
        this.definitionFileLoading.set(false);
      },
    });
  }

  closeFileView(): void {
    this.viewingFile.set(null);
    this.definitionFileContent.set(null);
  }

  /**
   * View a file from the agent list view (without navigating to definition view)
   */
  viewFileFromList(path: string, event: Event): void {
    event.stopPropagation();
    this.viewingFile.set({ type: 'context', path });
    this.definitionFileLoading.set(true);
    this.definitionFileContent.set(null);

    this.agentsService.readFile(path).subscribe({
      next: (response) => {
        this.definitionFileContent.set(response.content);
        this.definitionFileLoading.set(false);
      },
      error: (err) => {
        console.error('Failed to load file:', err);
        this.definitionFileContent.set('Error loading file');
        this.definitionFileLoading.set(false);
      },
    });
  }

  backFromDefinition(): void {
    this.viewMode.set('list');
    this.selectedDefinition.set(null);
    this.definitionFileContent.set(null);
    this.viewingFile.set(null);
    // Clear definition session state
    this.definitionSession.set(null);
    this.definitionChatInput.set('');
    this.definitionProcessing.set(false);
    this.sessionOutput.set([]);
    this.sessionError.set(null);
  }

  sendDefinitionMessage(): void {
    const message = this.definitionChatInput().trim();
    const definition = this.selectedDefinition();
    if (!message || !definition || this.definitionProcessing()) return;

    this.definitionChatInput.set('');
    this.sessionError.set(null);
    this.definitionProcessing.set(true);

    const existingSession = this.definitionSession();

    if (existingSession) {
      // Send follow-up message to existing session
      this.agentsService.sendMessage(existingSession.sessionId, message).subscribe({
        error: (err) => {
          this.sessionError.set(err.message || 'Failed to send message');
          this.definitionProcessing.set(false);
        },
      });
    } else {
      // Start a new session with this agent
      this.sessionOutput.set([]);
      this.agentsService.runAgent(definition.id, message).subscribe({
        next: (response) => {
          this.definitionSession.set(response.session);
          // Subscribe to session events
          this.wsService.subscribeToSession(response.session.sessionId);
        },
        error: (err) => {
          this.sessionError.set(err.message || 'Failed to start agent session');
          this.definitionProcessing.set(false);
        },
      });
    }
  }

  onDefinitionInputKeydown(event: KeyboardEvent): void {
    // Enter sends, Shift+Enter for newline
    if (event.key === 'Enter' && !event.shiftKey) {
      event.preventDefault();
      this.sendDefinitionMessage();
    }
  }

  toggleInfoSection(): void {
    this.infoCollapsed.update((v) => !v);
  }

  stopDefinitionSession(): void {
    const session = this.definitionSession();
    if (session) {
      this.agentsService.pauseSession(session.sessionId).subscribe({
        next: () => {
          this.definitionProcessing.set(false);
        },
        error: (err) => {
          this.sessionError.set(err.message || 'Failed to stop session');
        },
      });
    }
  }

  /**
   * Handle file selection for attachments
   */
  onFileSelect(event: Event, type: 'file' | 'image'): void {
    const input = event.target as HTMLInputElement;
    const files = input.files;
    if (!files) return;

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      const attachment = {
        id: `attachment-${this.attachmentIdCounter++}`,
        type,
        name: file.name,
        file,
        preview: undefined as string | undefined,
      };

      // Generate preview for images
      if (type === 'image') {
        const reader = new FileReader();
        reader.onload = (e) => {
          attachment.preview = e.target?.result as string;
          this.pendingAttachments.update((atts) => [...atts]);
        };
        reader.readAsDataURL(file);
      }

      this.pendingAttachments.update((atts) => [...atts, attachment]);
    }

    // Reset input
    input.value = '';
  }

  /**
   * Remove a pending attachment
   */
  removeAttachment(id: string): void {
    this.pendingAttachments.update((atts) => atts.filter((a) => a.id !== id));
  }

  private focusDefinitionChatInput(): void {
    setTimeout(() => {
      if (this.defChatInputEl) {
        this.defChatInputEl.nativeElement.focus();
      }
    }, 0);
  }

  getFileName(path: string): string {
    return path.split('/').pop() || path;
  }

  getCategoryIcon(category: string): string {
    switch (category) {
      case 'decomposition':
        return 'account_tree';
      case 'general':
        return 'smart_toy';
      default:
        return 'extension';
    }
  }
}
