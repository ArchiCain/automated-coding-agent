{
  "gateway": {
    "mode": "local",
    "port": 3001,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": []
    },
    "trustedProxies": [
      "10.244.0.0/16",
      "10.96.0.0/12",
      "127.0.0.1/32"
    ]
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "executablePath": "/usr/bin/chromium",
    "evaluateEnabled": true,
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true,
      "allowedHostnames": [
        "localhost",
        "127.0.0.1",
        "host.docker.internal"
      ]
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "apiKey": "ollama-local",
        "baseUrl": "http://graphics-machine:11434",
        "api": "ollama",
        "models": [
          {
            "id": "qwen-coder-next-256k",
            "name": "qwen-coder-next-256k",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 262144,
            "maxTokens": 32768
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "llm": {
        "idleTimeoutSeconds": 0
      },
      "subagents": {
        "allowAgents": ["orchestrator", "devops", "worker", "tester"],
        "maxSpawnDepth": 3,
        "maxChildrenPerAgent": 20,
        "maxConcurrent": 20,
        "runTimeoutSeconds": 1800
      },
      "compaction": {
        "model": "ollama/qwen-coder-next-256k",
        "identifierPolicy": "strict",
        "notifyUser": true
      },
      "memorySearch": {
        "provider": "openai",
        "model": "bge-m3-8k",
        "remote": {
          "baseUrl": "http://host-machine:11434/v1",
          "apiKey": "ollama-local"
        }
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "default": true,
        "model": "ollama/qwen-coder-next-256k",
        "workspace": "/workspace/.openclaw/workspaces/orchestrator",
        "agentDir": "/workspace/.openclaw/agents/orchestrator/agent",
        "skills": ["repo-tasks"],
        "identity": {
          "emoji": "🎯"
        }
      },
      {
        "id": "devops",
        "model": "ollama/qwen-coder-next-256k",
        "workspace": "/workspace/.openclaw/workspaces/devops",
        "agentDir": "/workspace/.openclaw/agents/devops/agent",
        "skills": ["repo-tasks"],
        "identity": {
          "emoji": "🛠"
        }
      },
      {
        "id": "worker",
        "model": "ollama/qwen-coder-next-256k",
        "workspace": "/workspace/.openclaw/workspaces/worker",
        "agentDir": "/workspace/.openclaw/agents/worker/agent",
        "skills": ["repo-tasks"],
        "identity": {
          "emoji": "⚙️"
        }
      },
      {
        "id": "tester",
        "model": "ollama/qwen-coder-next-256k",
        "workspace": "/workspace/.openclaw/workspaces/tester",
        "agentDir": "/workspace/.openclaw/agents/tester/agent",
        "skills": ["repo-tasks"],
        "identity": {
          "emoji": "🧪"
        }
      }
    ]
  },
  "memory": {
    "backend": "qmd",
    "qmd": {
      "paths": [
        { "name": "repo-docs",          "path": "/workspace/repo/.docs",                                   "pattern": "**/*.md" },
        { "name": "openclaw-docs",      "path": "/workspace/repo/projects/openclaw/.docs",                 "pattern": "**/*.md" },
        { "name": "app-backend-docs",   "path": "/workspace/repo/projects/application/backend/src/features",   "pattern": "**/.docs/**/*.md" },
        { "name": "app-frontend-docs",  "path": "/workspace/repo/projects/application/frontend/src/features",  "pattern": "**/.docs/**/*.md" },
        { "name": "tdt-backend-docs",   "path": "/workspace/repo/projects/the-dev-team/backend/src/features",  "pattern": "**/.docs/**/*.md" },
        { "name": "tdt-frontend-docs",  "path": "/workspace/repo/projects/the-dev-team/frontend/src/features", "pattern": "**/.docs/**/*.md" },
        { "name": "infra-docs",         "path": "/workspace/repo/infrastructure",                          "pattern": "**/.docs/**/*.md" }
      ],
      "sessions": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": false
  },
  "cron": {
    "enabled": true
  },
  "skills": {
    "load": {
      "extraDirs": ["./skills"]
    }
  },
  "plugins": {
    "allow": [
      "memory-core",
      "active-memory",
      "openclaw-honcho",
      "acpx",
      "browser",
      "device-pair"
    ],
    "slots": {
      "memory": "openclaw-honcho"
    },
    "entries": {
      "memory-core": {
        "enabled": true
      },
      "active-memory": {
        "enabled": false,
        "config": {
          "enabled": false,
          "agents": ["orchestrator", "devops", "worker", "tester"],
          "allowedChatTypes": ["direct"],
          "queryMode": "recent",
          "promptStyle": "balanced",
          "timeoutMs": 30000,
          "maxSummaryChars": 220,
          "logging": true
        }
      },
      "openclaw-honcho": {
        "enabled": true,
        "hooks": {
          "allowConversationAccess": true
        },
        "config": {
          "baseUrl": "http://localhost:8000",
          "workspaceId": "openclaw"
        }
      },
      "bonjour": {
        "enabled": false
      }
    }
  },
  "mcp": {
    "servers": {
      "gitnexus": {
        "command": "gitnexus",
        "args": ["mcp"]
      }
    }
  }
}
