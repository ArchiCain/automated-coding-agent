{
  "gateway": {
    "mode": "local",
    "port": 3001,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": []
    },
    "trustedProxies": [
      "10.244.0.0/16",
      "10.96.0.0/12",
      "127.0.0.1/32"
    ]
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "executablePath": "/usr/bin/chromium",
    "evaluateEnabled": true,
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true,
      "allowedHostnames": [
        "localhost",
        "127.0.0.1",
        "host.docker.internal"
      ]
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "apiKey": "ollama-local",
        "baseUrl": "http://graphics-machine:11434",
        "api": "ollama",
        "models": [
          {
            "id": "qwen-coder-next-256k",
            "name": "qwen-coder-next-256k",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 262144,
            "maxTokens": 32768
          }
        ]
      },
      "ollama-host": {
        "apiKey": "ollama-local",
        "baseUrl": "http://host-machine:11434",
        "api": "ollama",
        "models": [
          {
            "id": "gemma4-e4b-128k",
            "name": "gemma4-e4b-128k",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          },
          {
            "id": "qwen-coder-32k",
            "name": "qwen-coder-32k",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.5",
        "fallbacks": ["ollama/qwen-coder-next-256k"]
      },
      "subagents": {
        "allowAgents": [],
        "requireAgentId": true,
        "maxSpawnDepth": 3,
        "maxChildrenPerAgent": 20,
        "maxConcurrent": 20,
        "runTimeoutSeconds": 1800
      },
      "compaction": {
        "model": "ollama/qwen-coder-next-256k",
        "identifierPolicy": "strict",
        "notifyUser": true
      },
      "memorySearch": {
        "provider": "openai",
        "model": "bge-m3-8k",
        "remote": {
          "baseUrl": "http://host-machine:11434/v1",
          "apiKey": "ollama-local"
        }
      },
      "imageGenerationModel": {
        "primary": "openai/gpt-image-2"
      },
      "videoGenerationModel": {
        "primary": "openai/sora-2"
      }
    },
    "list": [
      {
        "id": "dev-main",
        "default": true,
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/dev-main",
        "agentDir": "/workspace/.openclaw/agents/dev-main/agent",
        "skills": ["repo-tasks"],
        "subagents": {
          "allowAgents": ["devops", "worker", "tester"]
        },
        "identity": {
          "emoji": "🎯"
        }
      },
      {
        "id": "devops",
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/devops",
        "agentDir": "/workspace/.openclaw/agents/devops/agent",
        "skills": ["repo-tasks"],
        "subagents": {
          "allowAgents": []
        },
        "identity": {
          "emoji": "🛠"
        }
      },
      {
        "id": "worker",
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/worker",
        "agentDir": "/workspace/.openclaw/agents/worker/agent",
        "skills": ["repo-tasks"],
        "subagents": {
          "allowAgents": ["tester"]
        },
        "identity": {
          "emoji": "⚙️"
        }
      },
      {
        "id": "tester",
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/tester",
        "agentDir": "/workspace/.openclaw/agents/tester/agent",
        "skills": ["repo-tasks"],
        "subagents": {
          "allowAgents": []
        },
        "identity": {
          "emoji": "🧪"
        }
      },
      {
        "id": "email-main",
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/email-main",
        "agentDir": "/workspace/.openclaw/agents/email-main/agent",
        "skills": [],
        "subagents": {
          "allowAgents": []
        },
        "identity": {
          "emoji": "📬"
        }
      },
      {
        "id": "backpacking-main",
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/backpacking-main",
        "agentDir": "/workspace/.openclaw/agents/backpacking-main/agent",
        "skills": [],
        "subagents": {
          "allowAgents": []
        },
        "identity": {
          "emoji": "🎒"
        }
      },
      {
        "id": "dnd-main",
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/dnd-main",
        "agentDir": "/workspace/.openclaw/agents/dnd-main/agent",
        "skills": [],
        "subagents": {
          "allowAgents": ["dnd-dm", "dnd-chargen"]
        },
        "identity": {
          "emoji": "🐉"
        }
      },
      {
        "id": "dnd-dm",
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/dnd-dm",
        "agentDir": "/workspace/.openclaw/agents/dnd-dm/agent",
        "skills": [],
        "subagents": {
          "allowAgents": []
        },
        "identity": {
          "emoji": "🎲"
        }
      },
      {
        "id": "dnd-chargen",
        "model": {
          "primary": "openai-codex/gpt-5.5",
          "fallbacks": ["ollama/qwen-coder-next-256k"]
        },
        "workspace": "/workspace/.openclaw/workspaces/dnd-chargen",
        "agentDir": "/workspace/.openclaw/agents/dnd-chargen/agent",
        "skills": [],
        "subagents": {
          "allowAgents": []
        },
        "identity": {
          "emoji": "🧙"
        }
      }
    ]
  },
  "memory": {
    "backend": "qmd",
    "qmd": {
      "paths": [
        { "name": "repo-docs",          "path": "/workspace/repo/.docs",                                   "pattern": "**/*.md" },
        { "name": "openclaw-docs",      "path": "/workspace/repo/projects/openclaw/.docs",                 "pattern": "**/*.md" },
        { "name": "app-backend-docs",   "path": "/workspace/repo/projects/application/backend/src/features",   "pattern": "**/.docs/**/*.md" },
        { "name": "app-frontend-docs",  "path": "/workspace/repo/projects/application/frontend/src/features",  "pattern": "**/.docs/**/*.md" },
        { "name": "tdt-backend-docs",   "path": "/workspace/repo/projects/the-dev-team/backend/src/features",  "pattern": "**/.docs/**/*.md" },
        { "name": "tdt-frontend-docs",  "path": "/workspace/repo/projects/the-dev-team/frontend/src/features", "pattern": "**/.docs/**/*.md" },
        { "name": "infra-docs",         "path": "/workspace/repo/infrastructure",                          "pattern": "**/.docs/**/*.md" }
      ],
      "sessions": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": false
  },
  "cron": {
    "enabled": true
  },
  "skills": {
    "load": {
      "extraDirs": ["./skills"]
    }
  },
  "plugins": {
    "allow": [
      "memory-core",
      "active-memory",
      "openclaw-honcho",
      "acpx",
      "browser",
      "device-pair"
    ],
    "slots": {
      "memory": "openclaw-honcho"
    },
    "entries": {
      "memory-core": {
        "enabled": true
      },
      "active-memory": {
        "enabled": false,
        "config": {
          "enabled": false,
          "agents": ["dev-main", "devops", "worker", "tester"],
          "allowedChatTypes": ["direct"],
          "queryMode": "recent",
          "promptStyle": "balanced",
          "timeoutMs": 30000,
          "maxSummaryChars": 220,
          "logging": true
        }
      },
      "openclaw-honcho": {
        "enabled": true,
        "hooks": {
          "allowConversationAccess": true
        },
        "config": {
          "baseUrl": "http://localhost:8000",
          "workspaceId": "openclaw"
        }
      },
      "bonjour": {
        "enabled": false
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "defaultAccount": "dev-main-bot",
      "dmPolicy": "allowlist",
      "groupPolicy": "allowlist",
      "allowFrom": ["8758890439"],
      "accounts": {
        "dev-main-bot": {
          "botToken": { "source": "env", "provider": "default", "id": "TELEGRAM_BOT_TOKEN_DEV_MAIN" }
        },
        "dnd-main-bot": {
          "botToken": { "source": "env", "provider": "default", "id": "TELEGRAM_BOT_TOKEN_DND_MAIN" }
        },
        "email-main-bot": {
          "botToken": { "source": "env", "provider": "default", "id": "TELEGRAM_BOT_TOKEN_EMAIL_MAIN" }
        },
        "backpacking-main-bot": {
          "botToken": { "source": "env", "provider": "default", "id": "TELEGRAM_BOT_TOKEN_BACKPACKING_MAIN" }
        }
      }
    }
  },
  "bindings": [
    { "match": { "channel": "telegram", "accountId": "dev-main-bot" },         "agentId": "dev-main" },
    { "match": { "channel": "telegram", "accountId": "dnd-main-bot" },         "agentId": "dnd-main" },
    { "match": { "channel": "telegram", "accountId": "email-main-bot" },       "agentId": "email-main" },
    { "match": { "channel": "telegram", "accountId": "backpacking-main-bot" }, "agentId": "backpacking-main" }
  ]
}
