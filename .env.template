# ============================================================================
# TAILSCALE (required)
# ============================================================================
# All services are accessed via Tailscale hostnames — localhost is not used.
# Run `task tailscale:hostname` to find your machine name.
# Run `tailscale ip -4` to find your Tailscale IP.

DEV_HOSTNAME=                        # e.g. shawns-macbook-pro
TAILSCALE_IP=                        # e.g. 100.64.158.57
TS_AUTHKEY=                          # Tailscale auth key for minikube gateway (local dev only)
                                     # Generate at: https://login.tailscale.com/admin/settings/keys
                                     # Use a reusable key (not ephemeral)
TS_GATEWAY_IP=                       # Tailscale IP of the gateway pod (check tailscale admin after first deploy)

# ============================================================================
# PROJECT IDENTITY
# ============================================================================

PROJECT_NAME=
COMPOSE_PROJECT_NAME=automated-repo

# ============================================================================
# REPOSITORY CONFIGURATION
# ============================================================================

REPO_ROOT=

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DATABASE_HOST=database
DATABASE_HOST_LOCAL=localhost
DATABASE_K8S_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=                   # required
DATABASE_NAME=postgres
DATABASE_SSL=false
DATABASE_LOGGING=true

# ============================================================================
# KEYCLOAK CONFIGURATION
# ============================================================================

KEYCLOAK_REALM=application
KEYCLOAK_CLIENT_ID=backend-service
KEYCLOAK_CLIENT_SECRET=backend-service-secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=             # required
KC_DB=postgres
KC_DB_SCHEMA=keycloak
KC_DB_URL=
KC_LOG_LEVEL=INFO
KC_TRANSACTION_XA_ENABLED=false
KC_IMPORT_OVERWRITE=true

# ============================================================================
# LLM API KEYS
# ============================================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=                   # required for THE Dev Team
GOOGLE_GENERATIVE_AI_API_KEY=

# ============================================================================
# THE DEV TEAM
# ============================================================================

# Claude Code OAuth token — run `claude setup-token` to generate (requires Max plan)
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub PAT for git operations (fine-grained, repo write access)
GITHUB_TOKEN=

# GitHub App credentials (for issue/PR automation)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=.github-app-private-key.pem
GITHUB_APP_PRIVATE_KEY_SECRET=github-app-key

# ============================================================================
# K8S DEPLOYMENT
# ============================================================================

DEPLOY_ENV=dev
NAMESPACE=app
THE_DEV_TEAM_NAMESPACE=the-dev-team
NODE_ENV=production
K8S_SERVICE_PORT=8080

# Service names (must match K8s service names)
BACKEND_SERVICE_NAME=backend
THE_DEV_TEAM_BACKEND_SERVICE_NAME=the-dev-team-backend

# Ingress hosts — derived from DEV_HOSTNAME by default, override only if needed
# BACKEND_HOST=api.${DEV_HOSTNAME}
# FRONTEND_HOST=app.${DEV_HOSTNAME}
# KEYCLOAK_HOST=auth.${DEV_HOSTNAME}
# THE_DEV_TEAM_BACKEND_HOST=agent-api.${DEV_HOSTNAME}
# THE_DEV_TEAM_FRONTEND_HOST=devteam.${DEV_HOSTNAME}

# Frontend API proxy (nginx routes /api/ to backend service)
FRONTEND_API_PROXY_SERVICE=backend
FRONTEND_API_PROXY_PORT=8080

# Container registry (in-cluster by default)
REGISTRY=localhost:30500

# Image tag (set per-deploy, defaults to latest)
# IMAGE_TAG=latest
