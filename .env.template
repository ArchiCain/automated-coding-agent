# Root .env — source of truth for the GitHub Actions deploy workflow.
#
# Copy to .env (gitignored), populate every required value, then run:
#
#   task setup:check      # validate nothing's missing or left at a placeholder
#   task gh:setup         # push the required values to GH secrets + variables
#
# 8 required values + 2 optional. Postgres credentials, the Keycloak
# client secret, and gateway constants live as literals in
# infrastructure/compose/{dev,openclaw}/compose.yml — no env reaches
# them anymore.

# ============================================================================
# REQUIRED — TAILSCALE (CI runner joins the tailnet)
# ============================================================================
# Reusable ephemeral authkey tagged tag:ci. Generate at:
#   https://login.tailscale.com/admin/settings/keys
# Mark it: Reusable + Ephemeral + Tags: tag:ci.
TS_AUTHKEY=

# ============================================================================
# REQUIRED — DEPLOY TARGET
# ============================================================================
# Tailscale hostname of the deploy host (host-machine role).
DEPLOY_HOST=host-machine

# ============================================================================
# REQUIRED — OLLAMA (consumed by the OpenClaw gateway)
# ============================================================================
# OpenClaw's bundled Ollama provider plugin requires a non-empty API key
# to activate, even for self-hosted Ollama. Any placeholder works.
# Endpoints themselves are configured in projects/openclaw/app/openclaw.json:
#   brain (chat)   -> http://graphics-machine:11434 (qwen-coder-next-256k)
#   memory (embed) -> http://host-machine:11434     (bge-m3-8k)
OLLAMA_API_KEY=ollama-local

# ============================================================================
# REQUIRED — OPENCLAW
# ============================================================================
# Browser-to-gateway pairing token. Generate:
#   openssl rand -hex 32
OPENCLAW_AUTH_TOKEN=

# ============================================================================
# REQUIRED — GITHUB APP (for the openclaw git-sync sidecar)
# ============================================================================
# Configuration page: https://github.com/settings/apps
# Required permissions on this repo: Contents: Read, Metadata: Read.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Local path to the App's private-key PEM. gh-setup.sh reads the file
# and pushes the contents as the GITHUB_APP_PRIVATE_KEY secret (which
# the workflow then writes to host:/srv/aca/secrets/github-app.pem).
GITHUB_APP_PRIVATE_KEY_PATH=.github-app-private-key.pem

# ============================================================================
# OPTIONAL — TELEGRAM BOTS (one bot per main agent)
# ============================================================================
# Each main agent gets its own Telegram bot for end-user chat. Leave any
# of these blank to disable that bot — the corresponding channels.telegram
# .accounts entry in openclaw.json should reference the env var name via
# secret-ref, so a missing token surfaces as a clear validation error
# rather than a silent half-configured bot.
#
# To create each bot: DM @BotFather on Telegram, run /newbot, copy the
# token. Repeat 4× (one per main agent). See
# projects/openclaw/.docs/standards/workspaces-pattern.md § "Telegram
# bot per main agent" for the full setup walkthrough.
TELEGRAM_BOT_TOKEN_DEV_MAIN=
TELEGRAM_BOT_TOKEN_DND_MAIN=
TELEGRAM_BOT_TOKEN_EMAIL_MAIN=
TELEGRAM_BOT_TOKEN_BACKPACKING_MAIN=

# ============================================================================
# OPTIONAL — only set if defaults don't fit your host
# ============================================================================
# SSH user on the deploy host. Leave blank to default to `ubuntu`.
DEPLOY_USER=

# gid of the host's `docker` group — the openclaw gateway container
# adds it as a supplemental group to access /var/run/docker.sock.
# Leave blank to default to 999 (Ubuntu's typical docker group GID).
# host-machine reports 988 — set explicitly if your host differs.
# Run `getent group docker | cut -d: -f3` on the deploy host to confirm.
DOCKER_SOCKET_GID=
