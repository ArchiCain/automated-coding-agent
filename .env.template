# Root .env — source of truth for the GitHub Actions deploy workflow.
#
# Copy to .env (gitignored), populate every value, then run:
#
#   task setup:check      # validate nothing's missing or left at a placeholder
#   task gh:setup         # push the required values to GH secrets + variables
#
# What lives here: every value the deploy workflow needs to render the
# host's compose .env files + the GitHub App PEM. What doesn't: anything
# compose-internal-only (port numbers, image tags, branch names) — those
# are in the compose files themselves.

# ============================================================================
# TAILSCALE — CI runner joins the tailnet to reach the deploy host
# ============================================================================
# Reusable ephemeral authkey tagged tag:ci. Generate at:
#   https://login.tailscale.com/admin/settings/keys
# Mark it: Reusable + Ephemeral + Tags: tag:ci.
TS_AUTHKEY=

# ============================================================================
# DEPLOY TARGET — where scripts/deploy.sh ssh's + rsync's + compose's
# ============================================================================
# Tailscale hostname of the deploy host (host-machine role).
DEPLOY_HOST=host-machine
# SSH user on the deploy host.
DEPLOY_USER=ubuntu
# gid of the host's `docker` group — the openclaw gateway container opens
# /var/run/docker.sock. Run on the host once:
#   getent group docker | cut -d: -f3
DOCKER_SOCKET_GID=

# ============================================================================
# DATABASE — shared postgres inside the dev compose stack
# ============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# ============================================================================
# KEYCLOAK
# ============================================================================
# Shared secret for the `backend-service` confidential client. Must match
# the clientSecret in projects/application/keycloak/app/realm-config/realm-export.json.
KEYCLOAK_CLIENT_SECRET=backend-service-secret

# ============================================================================
# LLM API KEYS — consumed by the OpenClaw gateway
# ============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================================
# OPENCLAW
# ============================================================================
# Browser-to-gateway pairing token. Generate:
#   openssl rand -hex 32
OPENCLAW_AUTH_TOKEN=

# ============================================================================
# GITHUB APP — for the openclaw git-sync sidecar (repo clone/pull auth)
# ============================================================================
# App configuration page: https://github.com/settings/apps
# Required permissions on this repo: Contents: Read, Metadata: Read.
# (Packages: Read is NOT required — GHCR packages are public on this repo.)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Local path to the App's private-key PEM. gh-setup.sh reads the file and
# pushes the contents as the GITHUB_APP_PRIVATE_KEY secret (which the
# workflow then writes to the host at /srv/aca/secrets/github-app.pem).
GITHUB_APP_PRIVATE_KEY_PATH=.github-app-private-key.pem
