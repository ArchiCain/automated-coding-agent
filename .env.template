# ============================================================================
# PROJECT IDENTITY
# ============================================================================

PROJECT_NAME=
COMPOSE_PROJECT_NAME=automated-repo

# ============================================================================
# REPOSITORY CONFIGURATION
# ============================================================================

REPO_ROOT=

# ============================================================================
# LOCAL DEVELOPMENT - PORTS
# ============================================================================
# These ports are used for local Docker services
# If you change these, update the URLs in the next section

BACKEND_PORT=8085
KEYCLOAK_PORT=8081
FRONTEND_PORT=3000
DATABASE_PORT=5437
PGWEB_PORT=8082

# Coding Agent (local-only services)
CODING_AGENT_BACKEND_PORT=8086
CODING_AGENT_FRONTEND_PORT=3001

# OpenClaw Gateway
OPENCLAW_PORT=18789

# ============================================================================
# LOCAL DEVELOPMENT - SERVICE URLS
# ============================================================================
# These must match the ports defined above

VITE_BACKEND_URL=http://localhost:8085
CORS_ORIGINS=http://localhost:3000

# Coding Agent URLs
VITE_CODING_AGENT_BACKEND_URL=http://localhost:8086
CODING_AGENT_CORS_ORIGINS=http://localhost:3001
CODING_AGENT_WORKSPACE_ROOT=

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DATABASE_HOST=database
DATABASE_HOST_LOCAL=localhost
DATABASE_K8S_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=postgres
DATABASE_SSL=false
DATABASE_LOGGING=true

# ============================================================================
# KEYCLOAK CONFIGURATION
# ============================================================================

KEYCLOAK_REALM=application
KEYCLOAK_CLIENT_ID=backend-service
KEYCLOAK_CLIENT_SECRET=backend-service-secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_DB=postgres
KC_DB_SCHEMA=keycloak
KC_DB_URL=
KC_LOG_LEVEL=INFO
KC_TRANSACTION_XA_ENABLED=false
KC_IMPORT_OVERWRITE=true

# ============================================================================
# LLM API KEYS
# ============================================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ============================================================================
# CODING AGENT CONFIGURATION
# ============================================================================

# Claude Code OAuth token (run `claude setup-token` to generate, requires Max plan)
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub PAT for git operations (fine-grained token with repo write access)
GITHUB_TOKEN=

# ============================================================================
# OPENCLAW CONFIGURATION
# ============================================================================

# GitHub webhook secret for authenticating webhook payloads (openssl rand -hex 32)
OPENCLAW_WEBHOOK_SECRET=

# Web UI authentication token (openssl rand -hex 32)
OPENCLAW_AUTH_TOKEN=

# ============================================================================
# K8S DEPLOYMENT (used by helmfile via env vars)
# ============================================================================
# These are used when deploying to K3s/K8s via helmfile.
# For local dev with Docker Compose, these are not needed.

DEPLOY_ENV=dev
NAMESPACE=app
CODING_AGENT_NAMESPACE=coding-agent
OPENCLAW_NAMESPACE=openclaw
NODE_ENV=production
K8S_SERVICE_PORT=8080
K8S_NODE=

# Service names (must match K8s service names for inter-service communication)
BACKEND_SERVICE_NAME=backend
CODING_AGENT_BACKEND_SERVICE_NAME=coding-agent-backend

# Hosts (set to your actual domain for production)
BACKEND_HOST=api.localhost
FRONTEND_HOST=app.localhost
KEYCLOAK_HOST=auth.localhost
CODING_AGENT_BACKEND_HOST=agent-api.localhost
CODING_AGENT_FRONTEND_HOST=agent.localhost
OPENCLAW_HOST=openclaw.localhost

# Frontend API proxy (nginx routes /api/ to backend service)
FRONTEND_API_PROXY_SERVICE=backend
FRONTEND_API_PROXY_PORT=8080
CODING_AGENT_FRONTEND_API_PROXY_SERVICE=coding-agent-backend
CODING_AGENT_FRONTEND_API_PROXY_PORT=8080
CODING_AGENT_FRONTEND_API_URL=
CODING_AGENT_FRONTEND_WS_URL=

# DNS (Tailscale Split DNS - resolves *.DOMAIN to this IP)
TAILSCALE_IP=
DNS_DOMAIN=

# Container registry (in-cluster by default, override with ECR/GHCR if needed)
REGISTRY=localhost:30500

# Image tag (set per-deploy, defaults to latest)
# IMAGE_TAG=latest
