# Root .env (copied from this template as `.env` at the repo root).
#
# Loaded by task's `dotenv: ['.env']` in Taskfile.yml. Tasks that run
# directly from the repo root see these variables in their environment.
# Most day-to-day work does NOT need anything here — the compose stack
# reads from per-project .env files:
#
#   infrastructure/compose/dev/.env       (postgres creds, keycloak secret)
#   infrastructure/compose/openclaw/.env  (API keys, gateway token, GitHub App)
#
# Use this file only for values you want visible to ad-hoc tasks at the
# repo root (e.g., `task backend:local:run` outside the compose stack).

# Optional: GitHub PAT for operator-level gh CLI actions from the repo root.
# Not needed for compose or OpenClaw (they use the GitHub App).
GITHUB_TOKEN=

# Optional: override image tag for deploy.sh / GH Actions. Defaults to
# `latest` on the scripts side; the GH workflow uses $GITHUB_SHA.
# IMAGE_TAG=
